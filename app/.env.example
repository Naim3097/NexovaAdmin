# =========================================================================
# Nexova Admin — environment template
# Copy to .env.local and fill in values.  NEVER commit .env.local.
#
# Sections 1–12 are EVERY variable the app code actually reads (validated in
# src/lib/env.ts). Section 13 lists planned integrations not yet wired in code.
# =========================================================================

# ---- 1. Site -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3001"   # prod = the real deployed URL
NEXT_PUBLIC_SITE_NAME="Nexova Admin"

# ---- 2. Data mode ------------------------------------------------------
# 0 = local .dev-data JSON store · 1 = all entities on Supabase ·
# or a comma list e.g. "leads,invoices". See src/lib/data/flag.ts.
USE_SUPABASE="1"
# 1 = bypass auth locally (DEV ONLY) · 0 = real Supabase auth. Keep 0 in prod.
DEV_AUTH_BYPASS="0"

# ---- 3. Supabase -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""         # server-only, never expose to client

# ---- 4. Resend (email) -------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM="Nexova <hello@nexovadigital.com>"

# ---- 5. Public lead intake (POST /api/public/leads) --------------------
PUBLIC_LEADS_SECRET=""               # shared secret the website sends as x-api-key

# ---- 5b. Cron (scheduled routes, e.g. /api/cron/task-reminders) ---------
CRON_SECRET=""                       # Vercel Cron sends Authorization: Bearer <this>

# ---- 6. AI -------------------------------------------------------------
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# ---- 7. Payments: LeanX (Malaysian FPX) --------------------------------
LEANX_API_BASE="https://api.leanx.dev"   # sandbox; production = https://api.leanx.io
LEANX_AUTH_TOKEN=""                  # header: LP-<MERCHANT>-MM|<UUID>|<TOKEN>
LEANX_COLLECTION_UUID=""             # which collection bills land in
LEANX_HASH_KEY=""                    # HMAC-SHA256 secret for webhook JWT verify

# ---- 8. n8n automation -------------------------------------------------
N8N_WEBHOOK_BASE=""                  # e.g. https://n8n.example.com/webhook
N8N_INBOUND_SECRET=""                # HMAC for n8n -> app callbacks

# ---- 9. Telegram -------------------------------------------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_TEAM_CHAT_ID=""

# ---- Agent API (external MCP / scrum-master access) --------------------
# Callers send a key as the `x-api-key` header on /api/agent. Each key is
# granted explicit scopes; a key can only invoke tools in its scopes.
# Scopes: read | write | outbound | email | destructive. Keys must be >=24 chars.
# Generate: openssl rand -hex 32
#
#   read        internal reads (board, standup, overdue, team)
#   write       internal mutations (add/toggle tasks, advance/assign stages)
#   outbound    external/real-world effects (payment links, Telegram, AI calls,
#               client-facing content review/approval)
#   email       sends email to clients (email.*) — its own scope so it can be
#               withheld from the agent independent of `outbound`.
#   destructive deletions / irreversible loss — HUMAN APPROVAL ONLY.
#
# The scrum-master agent gets read+write+outbound — NOT `email`, NOT
# `destructive` — so it can never email clients or delete (enforced by scope,
# the `deny` below is belt-and-suspenders). A separate admin key (a human)
# carries `email` + `destructive`:
#   AGENT_API_KEYS='[{"label":"scrum","key":"<32+ chars>","scopes":["read","write","outbound"],"deny":["email.*"]},{"label":"admin","key":"<32+ chars>","scopes":["read","write","outbound","email","destructive"]}]'
# `deny` accepts exact tool names or a prefix glob (e.g. "email.*", "payments.*").
AGENT_API_KEYS='[
  {"label":"scrum","key":"<scrum-key-openssl-rand-hex-32>","scopes":["read","write","outbound"],"deny":["email.*"]},
  {"label":"admin","key":"<admin-key-openssl-rand-hex-32>","scopes":["read","write","outbound","email","destructive"]}
]'
# Back-compat single key. AGENT_API_SCOPES is a comma list; defaults to "read".
# AGENT_API_DENY is a comma list of withheld tools (e.g. "email.*").
AGENT_API_KEY=""
AGENT_API_SCOPES="read"
AGENT_API_DENY=""
# Set to "1" ONLY behind a trusted proxy/LB (so x-forwarded-for is rewritten by
# it). Enables per-IP brute-force throttling; otherwise a global cap is used.
AGENT_TRUST_PROXY=""

# ---- Cal.com -----------------------------------------------------------
CALCOM_WEBHOOK_SECRET=""

# ---- 11. Cloudflare Turnstile (bot protection) -------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---- 12. Observability -------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# =========================================================================
